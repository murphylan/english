## 表格组件规范

### 组件层级

```
components/data-table/
├── data-table.tsx              # 标准表格（带分页）
├── data-table-virtualized.tsx  # 虚拟表格（大数据量 >100 条）
├── data-table-toolbar.tsx      # 工具栏（搜索/过滤）
├── data-table-column-header.tsx # 列头（排序/隐藏）
├── data-table-faceted-filter.tsx # 多选筛选器
├── data-table-date-filter.tsx   # 日期筛选器
├── data-table-slider-filter.tsx # 范围筛选器
├── data-table-pagination.tsx    # 分页控件
├── data-table-view-options.tsx  # 列显示控制
└── data-table-skeleton.tsx      # 加载骨架屏
```

### 列定义规范

列定义必须使用 `useMemo` 包裹，并配置 `meta` 属性启用筛选：

```tsx
import * as React from "react";
import type { ColumnDef } from "@tanstack/react-table";
import { Checkbox } from "@/components/ui/checkbox";
import { Badge } from "@/components/ui/badge";
import { DataTableColumnHeader } from "@/components/data-table/data-table-column-header";
import type { Entity } from "@/types/entity-types";

export function useColumns() {
  return React.useMemo<ColumnDef<Entity>[]>(
    () => [
      // 选择列
      {
        id: "select",
        size: 40,
        header: ({ table }) => (
          <Checkbox
            checked={table.getIsAllPageRowsSelected()}
            onCheckedChange={(value) => table.toggleAllPageRowsSelected(!!value)}
          />
        ),
        cell: ({ row }) => (
          <Checkbox
            checked={row.getIsSelected()}
            onCheckedChange={(value) => row.toggleSelected(!!value)}
          />
        ),
        enableSorting: false,
        enableHiding: false,
      },
      // 文本列 - 启用搜索
      {
        id: "title",
        accessorKey: "title",
        size: 200,
        header: ({ column }) => (
          <DataTableColumnHeader column={column} label="标题" />
        ),
        cell: ({ row }) => <span>{row.getValue("title")}</span>,
        enableSorting: true,
        enableColumnFilter: true,
        meta: {
          label: "标题",
          variant: "text",           // 文本搜索
          placeholder: "搜索标题...",
        },
      },
      // 选择列 - 启用下拉筛选
      {
        id: "status",
        accessorKey: "status",
        size: 120,
        header: ({ column }) => (
          <DataTableColumnHeader column={column} label="状态" />
        ),
        cell: ({ row }) => <Badge>{row.getValue("status")}</Badge>,
        enableSorting: true,
        enableColumnFilter: true,
        filterFn: (row, id, value) => value.includes(row.getValue(id)),
        meta: {
          label: "状态",
          variant: "select",         // 单选筛选
          // variant: "multiSelect", // 多选筛选
          options: [
            { label: "待处理", value: "pending" },
            { label: "进行中", value: "in_progress" },
            { label: "已完成", value: "completed" },
          ],
        },
      },
      // 日期列 - 启用日期筛选
      {
        id: "createdAt",
        accessorKey: "createdAt",
        size: 150,
        header: ({ column }) => (
          <DataTableColumnHeader column={column} label="创建时间" />
        ),
        cell: ({ row }) => formatDate(row.getValue("createdAt")),
        enableSorting: true,
        enableColumnFilter: true,
        meta: {
          label: "创建时间",
          variant: "dateRange",      // 日期范围筛选
        },
      },
      // 数值列 - 启用范围筛选
      {
        id: "priority",
        accessorKey: "priority",
        size: 100,
        header: ({ column }) => (
          <DataTableColumnHeader column={column} label="优先级" />
        ),
        enableSorting: true,
        enableColumnFilter: true,
        meta: {
          label: "优先级",
          variant: "range",          // 滑块范围筛选
          range: [1, 10],
        },
      },
      // 操作列 - 固定右侧
      {
        id: "actions",
        size: 80,
        header: "操作",
        cell: ({ row }) => <ActionMenu row={row} />,
        enableSorting: false,
        enableHiding: false,
        enablePinning: true,
      },
    ],
    []
  );
}
```

### Meta 属性类型

```typescript
interface ColumnMeta {
  label?: string;                    // 列标签
  placeholder?: string;              // 输入框占位符
  variant?:
    | "text"                         // 文本搜索
    | "number"                       // 数字输入
    | "select"                       // 单选筛选
    | "multiSelect"                  // 多选筛选
    | "date"                         // 单日期
    | "dateRange"                    // 日期范围
    | "range";                       // 滑块范围
  options?: Array<{                  // select/multiSelect 选项
    label: string;
    value: string;
    icon?: React.ComponentType;
    count?: number;
  }>;
  range?: [number, number];          // range 的最小最大值
  unit?: string;                     // number 的单位后缀
  toolbarOrder?: number;             // 工具栏中的排序位置（默认按列顺序）
}
```

### 虚拟表格特性

`DataTableVirtualized` 组件具备以下特性：

| 特性 | 说明 |
|------|------|
| **列宽自适应** | 使用 `ResizeObserver` 监听滚动容器宽度，列按比例自动扩展填满可用空间 |
| **粘性表头** | 表头使用 `sticky top-0` 固定在滚动区域顶部 |
| **虚拟滚动** | 只渲染可见行，支持大数据量（>1000 条）流畅滚动 |
| **深色适配** | 自动适配深色模式，表头/数据行颜色均有对应 |
| **高度自适应** | 默认 `height="auto"`，使用 Flex 布局自动填充剩余空间 |
| **横向滚动控制** | 列少时自适应填满、无横向滚动条；列多时出现横向滚动条 + 左侧固定列 |
| **固定列** | `stickyLeftCount` 指定左侧固定列数，固定列有实色背景 + 右侧阴影分隔 |

**样式规范：**
- 表头背景：`bg-gray-50`（浅色）/ `bg-gray-900`（深色）
- 表头文字：`text-gray-600` / `text-gray-400`，`font-medium`，`text-sm`
- 表头对齐：**`text-left`（左对齐）**，禁止使用 `text-center`
- 数据行文字：`text-gray-900` / `text-gray-100`
- 行悬停：`hover:bg-gray-50` / `hover:bg-gray-900`
- 边框：`border-gray-200` / `border-gray-800`

### 滚动条控制规范（强制）

**核心原则：横向滚动条仅在列总宽超出可用空间时才出现。**

**宽度测量（关键）：**
- ✅ `ResizeObserver` 必须观察**滚动容器**（`overflow: auto` 的元素），使用 `clientWidth`
- ❌ 禁止观察外层包裹容器 — 外层宽度包含边框和滚动条空间，会导致列缩放后溢出

```tsx
// ✅ 正确：观察滚动容器，clientWidth 自动扣除边框和竖向滚动条
React.useEffect(() => {
  const el = scrollRef.current;
  if (!el) return;
  const ro = new ResizeObserver(() => setWidth(el.clientWidth));
  ro.observe(el);
  setWidth(el.clientWidth);
  return () => ro.disconnect();
}, []);

// ❌ 错误：观察外层容器，宽度包含竖向滚动条占位
resizeObserver.observe(outerContainerRef.current);
setWidth(entry.contentRect.width); // 比实际可用宽大 ~17px
```

**滚动行为：**

| 场景 | 行为 |
|------|------|
| 列总宽 ≤ 可用宽度 | 列按比例扩展填满，**无横向滚动条** |
| 列总宽 > 可用宽度 | 列保持原始宽度，**出现横向滚动条** |
| 数据行多于可视区 | **出现竖向滚动条**，列宽自动适应剩余空间 |

**固定列（`stickyLeftCount`）：**

当列多需要横向滚动时，使用 `stickyLeftCount` 固定左侧关键列：

```tsx
// 固定第一列（如用户名），其余列可横向滚动
<DataTableVirtualized table={table} stickyLeftCount={1}>
  <DataTableToolbar table={table} />
</DataTableVirtualized>
```

固定列样式要求：
- 使用 `position: sticky; left: Xpx` 定位
- 数据单元格必须有**实色背景**（`bg-white`），否则滚动时内容透视
- 使用 `group` / `group-hover` 确保 hover 效果联动
- 最后一个固定列添加 `box-shadow` 右侧阴影作为视觉分隔

### 虚拟表格页面布局

表格页面使用 **Flex 布局自动填充**，无需硬编码高度：

**核心原则：**
1. 页面根容器使用 `flex h-full flex-col`
2. 标题区使用 `shrink-0` 固定高度
3. Card 使用 `flex-1 min-h-0` 自动填充剩余空间
4. CardContent 同样使用 `flex-1 min-h-0 flex-col`
5. DataTableVirtualized 默认 `height="auto"` 自动填充

```tsx
"use client";

import * as React from "react";
import { Card, CardContent } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { DataTableVirtualized } from "@/components/data-table/data-table-virtualized";
import { DataTableToolbar } from "@/components/data-table/data-table-toolbar";
import { useDataTable } from "@/hooks/use-data-table";

export default function EntityPage() {
  const columns = React.useMemo(() => [...], []);

  const { table } = useDataTable({
    tableId: "entity-list",
    data,
    columns,
    initialState: {
      pagination: { pageIndex: 0, pageSize: 50 },
      sorting: [{ id: "createdAt", desc: true }],
      columnVisibility: {
        batchId: false,
        memberNo: false,
      },
    },
    manualPagination: false,
    manualSorting: false,
    manualFiltering: false,
    syncQuery: false,
  });

  return (
    // 根容器：flex 布局，h-full 填满父容器
    <div className="flex h-full flex-col gap-4">
      {/* 页面标题区 - 固定高度 */}
      <div className="page-header shrink-0">
        <div>
          <h1 className="page-title text-xl">列表标题</h1>
          <p className="page-description text-xs">页面描述文字</p>
        </div>
        <div className="flex gap-2">
          <Button variant="outline">导出</Button>
          <Button>刷新</Button>
        </div>
      </div>

      {/* 表格区域 - 自动填充剩余高度 */}
      <Card className="card-enterprise flex min-h-0 flex-1 flex-col">
        <CardContent className="flex min-h-0 flex-1 flex-col pt-6">
          {/* height="auto" 是默认值，表格自动填充 Card 剩余空间 */}
          <DataTableVirtualized table={table}>
            <DataTableToolbar table={table} />
          </DataTableVirtualized>
        </CardContent>
      </Card>
    </div>
  );
}
```

**关键 CSS 类说明：**

| 类名 | 作用 |
|------|------|
| `h-full` | 高度填满父容器（需要父容器有明确高度） |
| `flex-1` | 占据剩余空间 |
| `min-h-0` | 允许 flex 子元素收缩（解决 overflow 问题） |
| `shrink-0` | 固定高度，不被压缩 |

**height 属性选项：**

```tsx
// 自动填充（推荐）
<DataTableVirtualized table={table} height="auto" />

// 固定像素高度
<DataTableVirtualized table={table} height={600} />

// CSS 计算值（不推荐，硬编码）
<DataTableVirtualized table={table} height="calc(100vh - 200px)" />
```

