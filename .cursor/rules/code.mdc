      <SheetDescription>描述文字</SheetDescription>
    </SheetHeader>

    {/* 中间 - 可滚动 */}
    <SheetBody>
      <div className="space-y-4">
        {/* 表单字段一行一个 */}
        <div className="space-y-2">
          <Label>字段名</Label>
          <Input placeholder="请输入..." />
        </div>
        {/* 状态选择器占半宽 */}
        <div className="w-1/2 space-y-2">
          <Label>状态</Label>
          <Select>...</Select>
        </div>
      </div>
